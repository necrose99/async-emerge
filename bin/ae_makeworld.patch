--- bin/ae_makeworld.orig	2013-04-02 12:00:00.000000000 +0000
+++ bin/ae_makeworld	2026-04-02 10:30:00.000000000 +0000
@@ -10,6 +10,10 @@
 # 2011-2013, Alex Dubenetsky: alexdu@forums.gentoo.org
 
 # get config
-. /etc/async.emerge.conf
+source ae_functions || exit 1
+ae_load_config || die "Could not load TOML configuration"
+
+# 2026 Modernization: Use TOML values for locking
+PNAME="ae_makeworld"
 
 # Detect VCS, set $AE_VCS
@@ -19,17 +23,17 @@
 # -v	verbose (copy out to stdout), default for GRS
 # -q	quite (don't copy out to stdout) default for VCS
 if (($AE_VCS)); then
-    [[ "$1" == '-v' ]] && AE_MW_VERBOSE='verbose'
+    [[ "$1" == '-v' ]] && AE_STRATEGY_VERBOSE=true
 else
-    [[ "$1" != '-q' ]] && AE_MW_VERBOSE='verbose'
+    [[ "$1" != '-q' ]] && AE_STRATEGY_VERBOSE=true
 fi
-[ "$AE_MW_VERBOSE" ] && einfo "($PNAME: verbose mode is ON)"
+[ "$AE_STRATEGY_VERBOSE" = true ] && einfo "($PNAME: verbose mode is ON)"
 
 # set config key prefix
 (($AE_VCS)) && eType='COOK' || eType='INSTALL' # COOK = VCS, INSTALL = GRS
 
 # check locking
-do_lock "${AE_DIR[RW]}/.makeworld.pid" 1 \
+do_lock "${AE_PATHS_UPPER}/.makeworld.pid" 1 \
 	"  $PNAME is already running! Exit."
 
 # emerge caller: info_msg emerge_cmd log_file_last warn_file_last log_file warn_file -> $cmdRet
@@ -40,11 +44,11 @@
 	[[ $1 ]] && einfo "  $1 ..."
 	# pre-logging emerging
 	dt_mark | tee -a "$log_last" &>> "$warn_last"
-	if [ "$AE_MW_VERBOSE" ]; then
+	if [ "$AE_STRATEGY_VERBOSE" = true ]; then
 		eval "(($2 2>&1 1>&3 | tee -a \"$warn_last\") 3>&1 1>&2 | tee -a \"$log_last\") 2>&1"
 	else
 		eval "$2 >> $log_last 2>> \"$warn_last\""
 	fi
