--- bin/ae_chroot.orig	2011-04-02 12:00:00.000000000 +0000
+++ bin/ae_chroot	2026-04-02 08:15:00.000000000 +0000
@@ -20,7 +20,13 @@
 mnt_special() { # 'y'/'n', fs dir, fs type
 	if [ "$1" == "y" ]; then
 		if [[ ! $(mount | grep "${AE_DIR[ROOT]}" | grep "$2") ]]; then
-			mount -vt $3 $3 "${AE_DIR[CHROOT]}/$2" &> /dev/null
+			# Use bind mounts for /dev, /run, /sys, /proc for better reliability
+			if [[ "$3" == "bind" ]]; then
+				mount --bind "/$2" "${AE_DIR[CHROOT]}/$2" &> /dev/null
+			else
+				mount -vt $3 $3 "${AE_DIR[CHROOT]}/$2" &> /dev/null
+			fi
+			
 			if (($?)); then
 				error "  Error mounting $2 fs to ${AE_DIR[CHROOT]}/$2!"
 				eend 1
