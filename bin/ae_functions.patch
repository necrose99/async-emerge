+# Patch 2026: TOML Integration & Unified Backend Fallback
+
+# ---------------------------------------------------------------------------
+# 1. TOML Configuration Loader
+# ---------------------------------------------------------------------------
+ae_load_config() {
+	local cfg="/etc/async-emerge.toml"
+	[[ -f "$cfg" ]] || { echo "ERR: $cfg missing!" >&2; return 1; }
+
+	# Parse TOML: [section] key = value -> AE_SECTION_KEY="value"
+	# Handles strings, booleans, and integers
+	while IFS='= ' read -r key val; do
+		if [[ $key =~ ^\[(.*)\]$ ]]; then
+			SECTION="${BASH_REMATCH[1]^^}"
+		elif [[ $key && $val ]]; then
+			val="${val%#*}"; val="${val% }"; val="${val# }"
+			val="${val#\"}"; val="${val%\"}"
+			export "AE_${SECTION}_${key^^}=$val"
+		fi
+	done < "$cfg"
+
+	# Legacy Map for backward compatibility
+	declare -g -A AE_DIR
+	AE_DIR[ROOT]="${AE_PATHS_ROOT:-/}"
+	AE_DIR[RW]="${AE_PATHS_UPPER:-/var/tmp/async-emerge/upper}"
+	AE_DIR[CHROOT]="${AE_PATHS_MOUNT:-/var/tmp/async-emerge/mnt}"
+	AE_DIR[LOG]="${AE_PATHS_LOG:-/var/log/async-emerge.log}"
+}
+
+# ---------------------------------------------------------------------------
+# 2. Unified UnionFS Mount Wrapper
+# ---------------------------------------------------------------------------
+_ae_root_mount() {
+	local KVER=$(uname -r); local KMAJ=$(echo "$KVER" | cut -d. -f1)
+	
+	# 1. Try AUFS (Modern br: syntax)
+	if grep -q 'aufs' /proc/filesystems || modprobe aufs 2>/dev/null; then
+		local A_OPTS="br:${AE_DIR[RW]}=rw:${AE_DIR[ROOT]}=ro,si=ae$$,nohino,verbose=0"
+		[[ $KMAJ -ge 6 ]] && A_OPTS+=",udba=notify"
+		if mount -t aufs -o "$A_OPTS" ae-aufs "${AE_DIR[CHROOT]}"; then
+			einfo "Mounted AUFS (Kernel $KVER)"
+			return 0
+		fi
+	fi
+
+	# 2. Try OverlayFS Fallback
+	if grep -qE '\boverlay(fs)?\b' /proc/filesystems || modprobe overlay 2>/dev/null; then
+		local O_WORK="${AE_DIR[RW]}.work"
+		mkdir -p "$O_WORK"
+		local O_OPTS="lowerdir=${AE_DIR[ROOT]},upperdir=${AE_DIR[RW]},workdir=$O_WORK"
+		[[ $KMAJ -ge 5 ]] && O_OPTS+=",xino=off,volatile"
+		if mount -t overlay -o "$O_OPTS" ae-ovl "${AE_DIR[CHROOT]}"; then
+			einfo "Mounted OverlayFS Fallback"
+			return 0
+		fi
+	fi
+	return 1
+}
